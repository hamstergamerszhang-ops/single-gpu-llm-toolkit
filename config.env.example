# Example config for catch_and_resume.sh.
#
# Copy to config.env and edit the values to match your training run, then run
# catch_and_resume.sh (it sources config.env if present). This replaces the
# previous in-script hardcoded block so you don't edit the script itself.

# Model + data paths
MODEL=./checkpoints/base_expanded_15b
DATA=./data/data_cpt_1        # dir containing train.jsonl [+ valid.jsonl]; ignored if CPT_CACHE set
CPT_CACHE=                    # e.g. ./cpt_cache/cache.jsonl -- takes priority over DATA if set
SAVE=./checkpoints/model_cpt_1

# Training hyperparams
TOTAL_ITERS=10000
CHECKPOINT_EVERY=500
BATCH=4
LR=5e-7
WARMUP_STEPS=50
MAX_SEQ_LEN=2048

# Supervisor behavior
HISTORY_KEEP=4                 # loss-tagged checkpoints to retain for rollback
LOSS_REGRESSION_FACTOR=1.5     # rollback if latest loss > this * best loss in history
MAX_SAME_POSITION_RETRIES=8     # stop if crashed at same step this many times
RETRY_SLEEP_SECS=10

# Multi-GPU support (AMD ROCm)
# For single-GPU (default): leave LAUNCHER and DISTRIBUTED as-is.
# For multi-GPU FSDP (e.g. 8x MI300X):
#   LAUNCHER="torchrun --nproc_per_node=8"
#   DISTRIBUTED="--fsdp"
# For multi-GPU DDP:
#   LAUNCHER="torchrun --nproc_per_node=8"
#   DISTRIBUTED="--ddp"
LAUNCHER=python3
DISTRIBUTED=

# Logging
LOG_PREFIX=./logs/cpt_1_autoresume
STOP_FILE=.stop_autoresume
